import /vendor/etc/init/hw/init.mtkgki.rc
import /vendor/etc/init/hw/init.pstore.rc

# MTK project .rc configure

on init
    mkdir /mnt/media_rw/usbotg 0700 media_rw media_rw
    mkdir /storage/usbotg 0700 root root

# BEGIN TINNO, 20230215，guoxiong2, add for keyboard  feature
on early-init
    chown system system /vendor/etc/tn_keyboard.ko
    chmod 0660 /vendor/etc/tn_keyboard.ko
    insmod /vendor/etc/tn_keyboard.ko
    chown system system /dev/ttyS3
    chmod 0666 /dev/ttyS3
# END TINNO, 20230215，guoxiong2, add for keyboard  feature

on post-fs-data

#Camera
    chmod 0660 /dev/MAINAF
    chown system camera /dev/MAINAF

    chmod 0660 /dev/MAINAF2
    chown system camera /dev/MAINAF2

    chmod 0660 /dev/SUBAF
    chown system camera /dev/SUBAF

    chmod 0660 /dev/GAF001AF
    chown system camera /dev/GAF001AF

    chmod 0660 /dev/DW9714AF
    chown system camera /dev/DW9714AF

    chmod 0660 /dev/LC898212AF
    chown system camera /dev/LC898212AF

    chmod 0660 /dev/BU64745GWZAF
    chown system camera /dev/BU64745GWZAF
#+PERIDOTW-692 PERIDOTW-717 PERIDOTW-718,chenming28,add, 20251016, disable UltraHDR
    setprop ro.camera.disableHeicUltraHDR 1
#-PERIDOTW-692 PERIDOTW-717 PERIDOTW-718,chenming28,add, 20251016, disable UltraHDR

#SMB
    chown system system /proc/smb/ScreenComm
    chmod 0660 /proc/smb/ScreenComm

    chmod 0660 /dev/spm
    chown system system /dev/spm

#+peridot-179,fangzhihua.wt,add, 20240307, add wakeup by TP double-click
    chown system system /proc/gesture_control
    chmod 0664 /proc/gesture_control
    chown system system /proc/game_mode
    chmod 0664 /proc/game_mode
    chown system system /proc/panel_direction
    chmod 0664 /proc/panel_direction
    chown system system /proc/support_pen
    chmod 0664 /proc/support_pen
    chown system system /proc/edge_grid_zone
    chmod 0664 /proc/edge_grid_zone
#-peridot-179,fangzhihua.wt,add, 20240307, add wakeup by TP double-click

# Add penlink patch
    chown system system /proc/Pen_ID
    chmod 0664 /proc/Pen_ID

#+Bug714485,liushaoqing.wt,20240220,ADD,sensor bringup
#For sar-sensor
    #Allow access to sar sensors device attributes
    chown system system /sys/class/capsense/power_enable
    chmod 0660  /sys/class/capsense/power_enable

    chown system system /sys/class/sensors/capsense_bottom_left/enable
    chown system system /sys/class/sensors/capsense_bottom_left/poll_delay
